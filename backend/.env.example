# Database Configuration
DATABASE_URL=postgresql://deforestation:deforestation@db:5432/deforestation_db
DATABASE_ECHO=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# JWT/Auth Configuration
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment
ENVIRONMENT=development
DEBUG=true

# PostGIS Configuration
GEOS_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/libgeos_c.so.1
PROJ_LIB=/usr/share/proj

# File Storage
UPLOAD_DIR=/app/uploads
MODELS_DIR=/app/models

# ML Model Paths
DEFORESTATION_MODEL_PATH=/app/models/deforestation_unet.pth

# Logging
LOG_LEVEL=INFO
