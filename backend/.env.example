SECRET_KEY=change-me-to-a-secure-value
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
ALERT_WEBHOOK_URL=
REDIS_URL=redis://redis:6379/0
